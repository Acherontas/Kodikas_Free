#include <iostream>
#include <sstream>
#include <iomanip>
#include <math.h>
#include "nmtostr.h"
using namespace std;

int main(int argc,char** argv)
{
    cout<<"enter ur number enter precision\n";
    long double urnm;
    urnm=stold(argv[1]);
    int preci;
    string sti;
    sti+=to_string(urnm);
    preci=stold(argv[2]);
    nmtostr *nmst=new nmtostr();
    string stil;
    for(int i=0;i<=sti.size()-1;i++){
        if(sti.at(i)=='.'){break;}
        if(sti.at(i)!='.'){stil+=sti.at(i);}
    }
    cout<<urnm << " " << sti <<" " << stil <<"\n";
    return 0;
}
